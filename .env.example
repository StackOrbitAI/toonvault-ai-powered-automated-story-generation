# ─────────────────────────────────────────────────────────────
# ToonVault — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!
# ─────────────────────────────────────────────────────────────

# ── Database ──
POSTGRES_USER=user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=toonvault

# ── JWT Authentication ──
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# ── AI Image Generation (Runware AI) ──
# Get your key at: https://my.runware.ai/
RUNWARE_API_KEY=your_runware_api_key_here
RUNWARE_MODEL=runware:100@1

# ── AI Story Writing (Mistral AI) ──
# Get your key at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Email (Optional) ──
# RESEND_API_KEY=your_resend_key_here
# EMAIL_FROM=noreply@yourdomain.com

# ── PayPal (Optional — for premium features) ──
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_SECRET=your_paypal_secret
